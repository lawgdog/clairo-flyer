<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap');
*{box-sizing:border-box;margin:0;padding:0;}
body{background:#f0f2f8;display:flex;justify-content:center;padding:40px 20px;font-family:'Manrope',sans-serif;}
.flyer{width:100%;max-width:680px;background:#FAFBFF;border-radius:16px;overflow:hidden;}
.banner{background:#00103D;padding:20px 28px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px;}
.banner-sub{font-size:11px;color:rgba(255,255,255,0.5);margin-top:4px;font-weight:400;}
.banner-badge{background:rgba(92,182,242,0.15);border:0.5px solid rgba(92,182,242,0.35);border-radius:20px;padding:5px 13px;font-size:11px;font-weight:500;color:#9AD6F7;white-space:nowrap;}
.hook{background:#00103D;border-bottom:1px solid rgba(92,182,242,0.2);padding:26px 28px 24px;}
.hook-hed{font-size:21px;font-weight:800;color:#fff;line-height:1.25;margin-bottom:10px;letter-spacing:-0.3px;}
.hook-hed span{color:#5CB6F2;}
.hook-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:16px 0 18px;}
.stat-box{background:rgba(92,182,242,0.12);border:0.5px solid rgba(92,182,242,0.3);border-radius:10px;padding:12px;text-align:center;}
.stat-num{font-size:19px;font-weight:800;color:#5CB6F2;line-height:1.1;}
.stat-label{font-size:11px;color:rgba(255,255,255,0.6);margin-top:3px;line-height:1.4;}
.hook-body{font-size:13.5px;color:rgba(255,255,255,0.72);line-height:1.7;font-weight:400;}
.hook-body+.hook-body{margin-top:10px;}
.body{padding:26px 28px;background:#FAFBFF;}
.section-label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#5CB6F2;margin-bottom:12px;}
.how-block{background:#fff;border:0.5px solid #D3D6E0;border-radius:12px;padding:20px;margin-bottom:24px;}
.how-intro{font-size:15px;font-weight:700;color:#00103D;margin-bottom:14px;line-height:1.35;}
.how-steps{list-style:none;padding:0;counter-reset:hs;}
.how-steps li{counter-increment:hs;display:flex;gap:12px;align-items:flex-start;padding:8px 0;border-bottom:0.5px solid #EDEFF7;}
.how-steps li:last-child{border-bottom:none;}
.how-steps li::before{content:counter(hs);background:#00103D;color:#5CB6F2;font-size:11px;font-weight:800;min-width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.hs-text{font-size:13.5px;color:#1E1E24;line-height:1.5;}
.hs-text strong{font-weight:700;color:#00103D;}
.aside-note{background:#EDEFF7;border-radius:10px;padding:11px 15px;margin-bottom:24px;font-size:12.5px;color:#6E7180;line-height:1.55;display:flex;align-items:flex-start;gap:8px;border:0.5px solid #D3D6E0;}
.aside-note a{color:#5CB6F2;font-weight:600;text-decoration:none;}
.divider{border:none;border-top:0.5px solid #D3D6E0;margin:22px 0;}
.tax-block{background:#EAF6FD;border:0.5px solid #9AD6F7;border-radius:12px;padding:18px 20px;margin-bottom:24px;}
.tax-hed{font-size:14px;font-weight:700;color:#00103D;margin-bottom:7px;}
.tax-body{font-size:13px;color:#40424D;line-height:1.65;}
.tax-body strong{color:#00103D;font-weight:700;}
.benefit-row{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;margin-bottom:24px;}
.benefit-item{background:#EDEFF7;border-radius:10px;padding:12px 13px;display:flex;align-items:flex-start;gap:10px;border:0.5px solid #D3D6E0;}
.bi-hed{font-size:13px;font-weight:700;color:#00103D;line-height:1.3;}
.bi-sub{font-size:12px;color:#6E7180;line-height:1.4;margin-top:2px;}
.why-block{background:#fff;border:0.5px solid #D3D6E0;border-radius:12px;padding:18px 20px;margin-bottom:24px;}
.why-hed{font-size:14px;font-weight:700;color:#00103D;margin-bottom:10px;}
.why-row{display:flex;gap:10px;margin-bottom:10px;align-items:flex-start;}
.why-row:last-child{margin-bottom:0;}
.why-row p{font-size:13px;color:#40424D;line-height:1.55;}
.why-row p strong{font-weight:700;color:#00103D;}
.why-icon{flex-shrink:0;margin-top:2px;width:20px;text-align:center;font-size:15px;}
.talk-block{background:#EAF6FD;border-radius:12px;border:0.5px solid #9AD6F7;padding:16px 18px;margin-bottom:4px;display:flex;gap:10px;align-items:flex-start;}
.talk-hed{font-size:14px;font-weight:700;color:#00103D;margin-bottom:4px;}
.talk-body{font-size:13px;color:#40424D;line-height:1.55;}
.cta-area{background:#00103D;padding:26px 28px;text-align:center;margin-top:26px;}
.cta-main{font-size:19px;font-weight:800;color:#fff;line-height:1.35;margin-bottom:8px;letter-spacing:-0.2px;}
.cta-main span{color:#5CB6F2;}
.cta-sub{font-size:13px;color:rgba(255,255,255,0.62);line-height:1.6;}
.cta-contact{margin-top:14px;font-size:14px;font-weight:700;color:#9AD6F7;}
.footnote{padding:12px 28px;font-size:11px;color:#9DA2B3;text-align:center;line-height:1.55;background:#FAFBFF;}
</style>
</head>
<body>
<div class="flyer">
